{
  "compilerOptions": {
    "target": "ES2020",
    "module": "None",
    "outFile": "assets/js/main.js",
    "rootDir": "src/ts",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "removeComments": true
  },
  "include": ["src/ts/**/*.ts"],
  "exclude": ["node_modules"]
}
